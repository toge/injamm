@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(glaze CONFIG REQUIRED)
find_dependency(FastFloat CONFIG REQUIRED)
if(@ENABLE_ENUM@)
  if(NOT TARGET enchantum::enchantum)
    find_path(_ENCHANTUM_INCLUDE_DIR enchantum/enchantum.hpp)
    if(NOT _ENCHANTUM_INCLUDE_DIR)
      message(FATAL_ERROR "injamm requires enchantum headers (enchantum/enchantum.hpp). Please install enchantum.")
    endif()
    add_library(enchantum::enchantum INTERFACE IMPORTED)
    set_target_properties(enchantum::enchantum PROPERTIES
      INTERFACE_INCLUDE_DIRECTORIES "${_ENCHANTUM_INCLUDE_DIR}"
    )
    unset(_ENCHANTUM_INCLUDE_DIR CACHE)
  endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/injammTargets.cmake")

# sqlite3 拡張が同じプレフィックスにインストールされていれば自動ロードする
set(_injamm_sqlite3_config_candidates
  "${CMAKE_CURRENT_LIST_DIR}/../injamm-sqlite3/injamm-sqlite3Config.cmake"
  "${CMAKE_CURRENT_LIST_DIR}/../../../share/injamm-sqlite3/injamm-sqlite3Config.cmake"
)
foreach(_injamm_sqlite3_config IN LISTS _injamm_sqlite3_config_candidates)
  if(EXISTS "${_injamm_sqlite3_config}")
    include("${_injamm_sqlite3_config}")
    break()
  endif()
endforeach()

check_required_components(injamm)
