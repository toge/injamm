@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
# injammConfig.cmake から include される場合はターゲットが既に定義済みのためスキップする
if(NOT TARGET injamm::injamm)
  find_dependency(injamm CONFIG REQUIRED)
endif()
find_dependency(unofficial-sqlite3 CONFIG REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/injamm-sqlite3Targets.cmake")

check_required_components(injamm-sqlite3)
